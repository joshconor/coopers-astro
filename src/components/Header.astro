---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";
---

<header
  class="sticky top-0 z-30 bg-white/80 backdrop-blur-xl border-b border-black/5"
>
  <div class="max-w-7xl mx-auto px-5 md:px-8 h-16 md:h-20 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3">
      <Image
        src={logo}
        alt="Coopers Grass Fed Beef"
        width={40}
        height={40}
        class="h-9 w-9 md:h-10 md:w-10 rounded-full object-cover ring-1 ring-black/5"
      />
      <span class="font-semibold text-pasture tracking-tight text-[15px] md:text-base">
        Coopers Grass Fed Beef
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8 text-[14px] font-medium text-ink/80">
      <a href="/#shop" class="hover:text-pasture transition">Shop</a>
      <a href="/#story" class="hover:text-pasture transition">Our Story</a>
      <a href="/#faq" class="hover:text-pasture transition">FAQ</a>
      <a href="/#contact" class="hover:text-pasture transition">Contact</a>
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="tel:2109034754"
        class="hidden sm:inline-flex items-center gap-2 text-[14px] font-medium text-pasture hover:text-pasture-dark"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
        (210) 903-4754
      </a>
      <a
        href="/#order"
        class="hidden md:inline-flex items-center bg-pasture text-white text-[14px] font-semibold px-4 py-2 rounded-full hover:bg-pasture-dark transition"
      >
        Order Now
      </a>
    </div>
  </div>
</header>
