---
import { faq } from "../data/faq";
---

<section id="faq" class="py-20 md:py-32 bg-surface-soft">
  <div class="max-w-4xl mx-auto px-5 md:px-8">
    <div class="reveal text-center mb-12 md:mb-16">
      <div class="text-[13px] font-semibold uppercase tracking-[0.18em] text-gold mb-3">Frequently Asked</div>
      <h2 class="font-sans font-bold text-[clamp(2rem,4.5vw,3.5rem)] tracking-tight text-pasture leading-[1.05]">
        Questions, answered.
      </h2>
    </div>

    <div class="reveal space-y-3">
      {faq.map((item, i) => (
        <details class="group bg-white rounded-2xl ring-1 ring-black/5 hover:ring-pasture/15 transition-all overflow-hidden">
          <summary class="cursor-pointer list-none flex items-center justify-between gap-6 p-6 md:p-7 select-none">
            <span class="font-semibold text-[16px] md:text-[17px] text-ink pr-4">{item.q}</span>
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-pasture/8 flex items-center justify-center group-open:rotate-45 transition-transform duration-300">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#1B3A57" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
          </summary>
          <div class="px-6 md:px-7 pb-6 md:pb-7 text-[15px] md:text-[16px] text-ink-muted leading-relaxed">
            {item.a}
          </div>
        </details>
      ))}
    </div>

    <div class="reveal mt-10 text-center">
      <p class="text-ink-muted text-[15px]">Still have questions?</p>
      <a href="#order" class="inline-block mt-2 text-pasture font-semibold hover:text-gold transition">Contact us →</a>
    </div>
  </div>
</section>
