---
const items = [
  { title: "100% Grass-Fed & Grass-Finished", body: "Birth to harvest — no grain, no corn, no feedlot.", icon: "leaf" },
  { title: "Family-Owned & Operated", body: "Same land, same family, same approach since 1996.", icon: "home" },
  { title: "Shipped Nationwide, Vacuum-Sealed", body: "Insulated, flash-frozen, arrives in 2–5 business days.", icon: "truck" },
];
---

<section class="py-16 md:py-24 border-y border-black/5 bg-white">
  <div class="max-w-7xl mx-auto px-5 md:px-8 grid md:grid-cols-3 gap-8 md:gap-12">
    {items.map((item) => (
      <div class="reveal flex flex-col items-start">
        <div class="w-12 h-12 rounded-2xl bg-pasture/8 flex items-center justify-center mb-4">
          {item.icon === "leaf" && (
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1B3A57" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>
          )}
          {item.icon === "home" && (
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1B3A57" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          )}
          {item.icon === "truck" && (
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1B3A57" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
          )}
        </div>
        <h3 class="font-semibold text-[18px] text-ink mb-2">{item.title}</h3>
        <p class="text-ink-muted text-[15px] leading-relaxed">{item.body}</p>
      </div>
    ))}
  </div>
</section>
