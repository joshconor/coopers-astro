---
const year = new Date().getFullYear();
---

<footer class="bg-pasture text-white/90 mt-24">
  <div class="max-w-7xl mx-auto px-5 md:px-8 py-14 md:py-20 grid grid-cols-1 md:grid-cols-4 gap-10">
    <div class="md:col-span-2">
      <h3 class="font-display text-2xl text-white mb-3">Coopers Grass Fed Beef</h3>
      <p class="text-white/70 leading-relaxed max-w-md text-[15px]">
        Family-owned since 1996. 100% grass-fed and grass-finished beef, plus pasture-raised pork. Shipped nationwide.
      </p>

      <div class="flex items-center gap-3 mt-6">
        <a
          href="https://www.facebook.com/share/1XQdT98Lx8/?mibextid=wwXIfr"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="w-9 h-9 rounded-full bg-white/10 hover:bg-gold hover:text-pasture text-white flex items-center justify-center transition"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.51 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"/></svg>
        </a>
        <a
          href="https://www.tiktok.com/@grass_fed_cattle_beef"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="TikTok"
          class="w-9 h-9 rounded-full bg-white/10 hover:bg-gold hover:text-pasture text-white flex items-center justify-center transition"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.69a8.16 8.16 0 0 0 4.77 1.52V6.76a4.85 4.85 0 0 1-1.84-.07z"/></svg>
        </a>
        <a
          href="https://wa.me/12542187695"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="WhatsApp"
          class="w-9 h-9 rounded-full bg-white/10 hover:bg-gold hover:text-pasture text-white flex items-center justify-center transition"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-1.7-.8-2.7-1.5-3.8-3.5-.3-.5.3-.5.8-1.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.4-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1 2.9 1.2 3.1c.1.2 2.1 3.2 5.1 4.5 1.9.7 2.6.8 3.6.6.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.2-.3-.2-.6-.4z M12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.2-1.3c1.4.8 3 1.2 4.7 1.2h.1c5.5 0 10-4.5 10-10S17.5 2 12 2zm0 18.3c-1.5 0-3-.4-4.3-1.2l-.3-.2-3.2.8.8-3.1-.2-.3a8.3 8.3 0 1 1 7.2 4z"/></svg>
        </a>
      </div>
    </div>

    <div>
      <h4 class="font-semibold text-white mb-4 text-[14px] tracking-wider uppercase">Shop</h4>
      <ul class="space-y-2 text-[15px] text-white/75">
        <li><a href="/#shop" class="hover:text-gold transition">Beef Shares</a></li>
        <li><a href="/#shop" class="hover:text-gold transition">Pork Shares</a></li>
        <li><a href="/#order" class="hover:text-gold transition">Order Now</a></li>
      </ul>
    </div>

    <div>
      <h4 class="font-semibold text-white mb-4 text-[14px] tracking-wider uppercase">Visit</h4>
      <address class="not-italic text-[15px] text-white/75 space-y-2 leading-relaxed">
        <div>Amarillo, TX</div>
        <div><a href="tel:2109034754" class="hover:text-gold transition">(210) 903-4754</a></div>
        <div><a href="https://wa.me/12542187695" target="_blank" rel="noopener noreferrer" class="hover:text-gold transition">WhatsApp: (254) 218-7695</a></div>
        <div><a href="mailto:Coopergrassfedbeef@gmail.com" class="hover:text-gold transition">Coopergrassfedbeef@gmail.com</a></div>
      </address>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-5 md:px-8 py-6 text-[13px] text-white/50 flex flex-col md:flex-row md:justify-between gap-2">
      <div>© {year} Coopers Grass Fed Beef. All rights reserved.</div>
      <div>Real beef. Raised right. Shipped to your door.</div>
    </div>
  </div>
</footer>
