---
const year = new Date().getFullYear();
---

<footer class="bg-pasture text-white/90 mt-24">
  <div class="max-w-7xl mx-auto px-5 md:px-8 py-14 md:py-20 grid grid-cols-1 md:grid-cols-4 gap-10">
    <div class="md:col-span-2">
      <h3 class="font-display text-2xl text-white mb-3">Coopers Grass Fed Beef</h3>
      <p class="text-white/70 leading-relaxed max-w-md text-[15px]">
        Family-owned since 1996. 100% grass-fed and grass-finished beef, plus pasture-raised pork. Shipped nationwide.
      </p>
    </div>

    <div>
      <h4 class="font-semibold text-white mb-4 text-[14px] tracking-wider uppercase">Shop</h4>
      <ul class="space-y-2 text-[15px] text-white/75">
        <li><a href="/#shop" class="hover:text-gold transition">Beef Shares</a></li>
        <li><a href="/#shop" class="hover:text-gold transition">Pork Shares</a></li>
        <li><a href="/#order" class="hover:text-gold transition">Order Now</a></li>
      </ul>
    </div>

    <div>
      <h4 class="font-semibold text-white mb-4 text-[14px] tracking-wider uppercase">Visit</h4>
      <address class="not-italic text-[15px] text-white/75 space-y-2 leading-relaxed">
        <div>City, State</div>
        <div><a href="tel:5551234567" class="hover:text-gold transition">(555) 123-4567</a></div>
        <div><a href="mailto:jconor624@gmail.com" class="hover:text-gold transition">jconor624@gmail.com</a></div>
      </address>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-5 md:px-8 py-6 text-[13px] text-white/50 flex flex-col md:flex-row md:justify-between gap-2">
      <div>© {year} Coopers Grass Fed Beef. All rights reserved.</div>
      <div>Real beef. Raised right. Shipped to your door.</div>
    </div>
  </div>
</footer>
