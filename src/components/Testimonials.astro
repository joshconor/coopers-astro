---
const reviews = [
  { quote: "Best beef my family's ever had. The ribeye is on another level.", name: "Marcus T.", state: "Texas" },
  { quote: "Ordered the 1/4 share and it lasted us six months. Worth every penny.", name: "Sarah K.", state: "Ohio" },
  { quote: "Josh kept me updated the whole way. Real customer service from a real farm.", name: "David R.", state: "Georgia" },
  { quote: "Tastes how beef is supposed to taste. We won't go back to grocery store meat.", name: "The Hendersons", state: "Florida" },
];
---

<section class="py-20 md:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-5 md:px-8">
    <div class="reveal text-center mb-12 md:mb-16 max-w-2xl mx-auto">
      <div class="text-[13px] font-semibold uppercase tracking-[0.18em] text-gold mb-3">Reviews</div>
      <h2 class="font-sans font-bold text-[clamp(2rem,4.5vw,3.25rem)] tracking-tight text-pasture leading-[1.05]">
        Families who've never gone back.
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
      {reviews.map((r) => (
        <figure class="reveal bg-surface-soft rounded-3xl p-7 ring-1 ring-black/5 flex flex-col">
          <div class="flex gap-0.5 mb-4 text-gold">
            {[1,2,3,4,5].map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>
          <blockquote class="text-[15px] text-ink leading-relaxed flex-1">"{r.quote}"</blockquote>
          <figcaption class="mt-5 text-[13px] text-ink-muted">
            <span class="font-semibold text-ink">{r.name}</span> · {r.state}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
