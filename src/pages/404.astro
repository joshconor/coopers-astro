---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Page Not Found | Coopers Grass Fed Beef"
  description="The page you're looking for doesn't exist. Head home and browse our beef and pork shares."
>
  <section class="min-h-[70vh] flex items-center justify-center bg-surface-soft px-5 py-24">
    <div class="reveal max-w-xl text-center">
      <div class="text-[13px] font-semibold uppercase tracking-[0.18em] text-gold mb-3">
        404 — Page Not Found
      </div>

      <h1 class="font-sans font-bold text-[clamp(2.25rem,5vw,3.75rem)] leading-[1.05] tracking-tight text-pasture">
        That trail leads nowhere.
      </h1>

      <p class="mt-5 text-[17px] md:text-[18px] text-ink-muted leading-relaxed">
        The page you tried to reach has wandered off the pasture. Let's get you back to the herd.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center bg-pasture text-white font-semibold px-7 py-4 rounded-full hover:bg-pasture-dark transition shadow-lg shadow-pasture/20"
        >
          Back to Home
        </a>
        <a
          href="/#shop"
          class="inline-flex items-center justify-center bg-white border border-black/10 text-pasture font-semibold px-7 py-4 rounded-full hover:bg-surface-soft transition"
        >
          Shop the cuts →
        </a>
      </div>

      <p class="mt-10 text-[14px] text-ink-muted">
        Need help? Call <a href="tel:2109034754" class="text-pasture font-semibold hover:text-pasture-dark">(210) 903-4754</a>
        or email <a href="mailto:Coopersgrassfedbeef@gmail.com" class="text-pasture font-semibold hover:text-pasture-dark">Coopersgrassfedbeef@gmail.com</a>.
      </p>
    </div>
  </section>
</Layout>
